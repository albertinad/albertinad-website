---
type Props = {
  title: string;
};
const { title } = Astro.props;
---

<div class="section-header">
  <h2 class="title">{title}</h2>
</div>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
  }

  .title {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
    margin: 0;
  }
</style>
