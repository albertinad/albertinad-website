---
import { useTranslations } from '@/i18n/utils';
import SectionHeader from './SectionHeader.astro';

const translate = useTranslations(Astro.currentLocale);
---

<section class="about">
  <SectionHeader title={translate('about.section.title')} />
  <div class="body">
    <p class="text">
      {translate('about.body.intro')}
      <br />
      <br />
      {translate('about.body.p2')}
    </p>
  </div>
</section>

<style>
  .about {
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.55s forwards;
  }

  .body {
    max-width: 680px;
  }

  .text {
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    font-weight: 300;
    line-height: 1.8;
    color: var(--fg);
    margin: 0;
  }
</style>
