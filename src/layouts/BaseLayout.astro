---
import '@/index.css';
import 'styled-system/styles.css';
import { AvailableThemes } from '@/typings';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Albertina Durante — Staff Software Engineer',
  description = 'Albertina Durante is a Staff Software Engineer with an MSc in Information Systems Engineering. Expertise in backend, frontend, and full-stack development across big tech and startups, specializing in reliable, scalable, and performant systems.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Albertina Durante" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://albertinad.com/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://albertinad.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Albertina Durante" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#fafaf7" />

    <!-- Structured Data: JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Albertina Durante",
        "url": "https://albertinad.com",
        "jobTitle": "Staff Software Engineer",
        "description": "Staff Software Engineer with an MSc in Information Systems Engineering and a decade of experience across backend, frontend, and full-stack development.",
        "sameAs": ["https://github.com/albertinad", "https://linkedin.com/in/albertina-durante/"]
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,200;0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={AvailableThemes.LIGHT}>
    <slot />
  </body>
</html>
